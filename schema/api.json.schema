{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/aip/schema/aip-core.schema.json",
  "title": "Agent Interaction Protocol (AIP) Core Schema",
  "description": "Initial draft schema for a provider-neutral orchestration protocol.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "participants",
    "artifacts",
    "steps"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^aip\\/[A-Za-z0-9._-]+$",
      "examples": ["aip/v0.1"]
    },
    "kind": {
      "type": "string",
      "const": "Flow"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/participant"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "default": []
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "subflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subflowRef"
      },
      "default": []
    },
    "providerBinding": {
      "$ref": "#/$defs/providerBinding"
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "type": "string",
          "enum": ["agent", "service", "tool", "api", "human", "subflow"]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "schemaRef"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/aipRef"
        },
        "schemaRef": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/id"
        },
        "consumers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "required": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string",
          "enum": [
            "invoke",
            "fanOut",
            "fanIn",
            "branch",
            "await",
            "exit"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "participantRef": {
          "$ref": "#/$defs/id"
        },
        "subflowRef": {
          "type": "string",
          "minLength": 1
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "consumes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/aipRef"
          },
          "default": []
        },
        "produces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/aipRef"
          },
          "default": []
        },
        "operator": {
          "$ref": "#/$defs/operator"
        },
        "branch": {
          "$ref": "#/$defs/branch"
        },
        "iteration": {
          "$ref": "#/$defs/iteration"
        },
        "onFailure": {
          "$ref": "#/$defs/transition"
        },
        "onSuccess": {
          "$ref": "#/$defs/transition"
        },
        "awaitInput": {
          "$ref": "#/$defs/awaitInput"
        },
        "exit": {
          "$ref": "#/$defs/exit"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "invoke" }
            }
          },
          "then": {
            "anyOf": [
              { "required": ["participantRef"] },
              { "required": ["subflowRef"] }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "branch" }
            }
          },
          "then": {
            "required": ["branch"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "await" }
            }
          },
          "then": {
            "required": ["awaitInput"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "exit" }
            }
          },
          "then": {
            "required": ["exit"]
          }
        }
      ]
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["summarize", "rank", "merge", "filter", "await"]
        },
        "mode": {
          "type": "string"
        },
        "criteriaRef": {
          "$ref": "#/$defs/aipRef"
        },
        "topN": {
          "type": "integer",
          "minimum": 1
        },
        "config": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases"],
      "properties": {
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/branchCase"
          }
        },
        "default": {
          "$ref": "#/$defs/transition"
        }
      }
    },
    "branchCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "next"],
      "properties": {
        "when": {
          "type": "object",
          "description": "Provider-neutral condition expression placeholder.",
          "additionalProperties": true
        },
        "next": {
          "$ref": "#/$defs/transition"
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nextStep": {
          "$ref": "#/$defs/id"
        },
        "nextSteps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1
        }
      },
      "oneOf": [
        { "required": ["nextStep"] },
        { "required": ["nextSteps"] }
      ]
    },
    "iteration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["forEach", "while", "bounded"]
        },
        "collectionRef": {
          "$ref": "#/$defs/aipRef"
        },
        "condition": {
          "type": "object",
          "description": "Provider-neutral condition expression placeholder.",
          "additionalProperties": true
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "awaitInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "schemaRef"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/aipRef"
        },
        "schemaRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceParticipantRef": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "exit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "failure", "cancelled", "blocked"]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "subflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uri"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        }
      }
    },
    "providerBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerRef"],
      "properties": {
        "providerRef": {
          "type": "string",
          "minLength": 1
        },
        "participantBindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/participantBinding"
          },
          "default": []
        },
        "artifactBindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactBinding"
          },
          "default": []
        },
        "config": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "participantBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participantRef", "providerTarget"],
      "properties": {
        "participantRef": {
          "$ref": "#/$defs/id"
        },
        "providerTarget": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      }
    },
    "artifactBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactRef", "providerRef"],
      "properties": {
        "artifactRef": {
          "$ref": "#/$defs/aipRef"
        },
        "providerRef": {
          "type": "string"
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "aipRef": {
      "type": "string",
      "pattern": "^aip://[A-Za-z0-9._/-]+$"
    }
  }
}
