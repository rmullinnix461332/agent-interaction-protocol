{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/aip/schema/aip-core.schema.json",
  "title": "Agent Interaction Protocol (AIP) Core Schema",
  "description": "Draft schema for provider-neutral orchestration.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "participants", "artifacts", "steps"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^aip\\/[A-Za-z0-9._-]+$",
      "examples": ["aip/v0.1"]
    },
    "kind": {
      "type": "string",
      "const": "Flow"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/participant" }
    },
    "artifacts": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/artifact" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "providerBinding": {
      "$ref": "#/$defs/providerBinding"
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },

    "aipRef": {
      "type": "string",
      "pattern": "^aip://[A-Za-z0-9._/-]+$"
    },

    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": {
          "type": "string",
          "enum": ["agent", "service", "human", "subflow"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "flowRef": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "const": "subflow" }
            }
          },
          "then": {
            "required": ["flowRef"]
          }
        }
      ]
    },

    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "$ref": "#/$defs/aipRef" },
        "contentType": {
          "type": "string",
          "minLength": 1,
          "default": "text/markdown"
        },
        "contractRef": {
          "type": "string",
          "minLength": 1
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "producer": { "$ref": "#/$defs/id" },
        "consumers": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "metadata": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      }
    },

    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": {
          "type": "string",
          "enum": ["action", "fanOut", "fanIn", "decision", "await", "exit"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },

        "participantRef": { "$ref": "#/$defs/id" },

        "dependsOn": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        },

        "consumes": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/aipRef" }
        },

        "produces": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/aipRef" }
        },

        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "minItems": 1
        },

        "condition": {
          "type": "string",
          "enum": ["allSuccess", "anySuccess", "allComplete"],
          "default": "allSuccess"
        },

        "operator": { "$ref": "#/$defs/operator" },

        "decision": { "$ref": "#/$defs/decision" },

        "iteration": { "$ref": "#/$defs/iteration" },

        "awaitInput": { "$ref": "#/$defs/awaitInput" },

        "exit": { "$ref": "#/$defs/exit" },

        "extensions": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      },

      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "action" } }
          },
          "then": {
            "required": ["participantRef"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "fanOut" } }
          },
          "then": {
            "required": ["steps"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "fanIn" } }
          },
          "then": {
            "properties": {
              "condition": {
                "type": "string",
                "enum": ["allSuccess", "anySuccess", "allComplete"],
                "default": "allSuccess"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "decision" } }
          },
          "then": {
            "required": ["decision"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "await" } }
          },
          "then": {
            "required": ["awaitInput"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "exit" } }
          },
          "then": {
            "required": ["exit"]
          }
        }
      ]
    },

    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["summarize", "rank", "merge", "filter", "await"]
        },
        "mode": {
          "type": "string"
        },
        "criteriaRef": {
          "$ref": "#/$defs/aipRef"
        },
        "topN": {
          "type": "integer",
          "minimum": 1
        },
        "config": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      }
    },

    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases"],
      "properties": {
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/decisionCase" }
        },
        "default": {
          "$ref": "#/$defs/decisionNext"
        }
      }
    },

    "decisionCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "next"],
      "properties": {
        "when": {
          "type": "object",
          "description": "Provider-neutral condition expression placeholder.",
          "additionalProperties": true
        },
        "next": {
          "$ref": "#/$defs/decisionNext"
        }
      }
    },

    "decisionNext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nextStep": { "$ref": "#/$defs/id" },
        "nextSteps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      },
      "oneOf": [
        { "required": ["nextStep"] },
        { "required": ["nextSteps"] }
      ]
    },

    "iteration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["forEach", "while", "bounded"]
        },
        "collectionRef": {
          "$ref": "#/$defs/aipRef"
        },
        "condition": {
          "type": "object",
          "description": "Provider-neutral condition expression placeholder.",
          "additionalProperties": true
        },
        "strategy": {
          "type": "string",
          "enum": ["serial", "parallel"]
        },
        "outputMode": {
          "type": "string",
          "enum": ["append", "replace", "merge"]
        },
        "onItemFailure": {
          "type": "string",
          "enum": ["stop", "continue", "collect"]
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1
        },
        "timeout": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["step", "subflow"]
            },
            "ref": {
              "type": "string"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "forEach" } }
          },
          "then": {
            "required": ["collectionRef"]
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "while" } }
          },
          "then": {
            "required": ["condition"]
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "bounded" } }
          },
          "then": {
            "required": ["maxIterations"]
          }
        }
      ]
    },

    "awaitInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "$ref": "#/$defs/aipRef" },
        "contentType": {
          "type": "string",
          "minLength": 1,
          "default": "text/markdown"
        },
        "contractRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceParticipantRef": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string"
        }
      }
    },

    "exit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "failure", "cancelled", "blocked"]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },

    "providerBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerRef"],
      "properties": {
        "providerRef": {
          "type": "string",
          "minLength": 1
        },
        "participantBindings": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/participantBinding" }
        },
        "artifactBindings": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/artifactBinding" }
        },
        "config": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      }
    },

    "participantBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participantRef", "providerTarget"],
      "properties": {
        "participantRef": { "$ref": "#/$defs/id" },
        "providerTarget": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      }
    },

    "artifactBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactRef", "providerRef"],
      "properties": {
        "artifactRef": { "$ref": "#/$defs/aipRef" },
        "providerRef": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
